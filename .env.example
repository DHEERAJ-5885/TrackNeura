# 🌐 TRACKNEURA ENVIRONMENT CONFIGURATION
# Copy this file to .env and fill in your API keys

# 🤖 GEMINI AI CHATBOT
# Get your free API key at: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# 🗺️ GOOGLE MAPS & PLACES API (for WiFi Finder)
# Get API key at: https://console.cloud.google.com/apis/credentials
# Enable: Maps JavaScript API, Places API, Geocoding API
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# 📡 OPENWIFIMAP API (optional - for crowdsourced WiFi data)
# Register at: https://openwifimap.net/api
OPENWIFIMAP_API_KEY=your_openwifimap_api_key_here

# 🇮🇳 PM-WANI API (optional - for India's public WiFi)
# Register with PM-WANI providers
PMWANI_API_KEY=your_pmwani_api_key_here

# 🔐 FLASK CONFIGURATION
FLASK_SECRET_KEY=your_super_secret_key_here
FLASK_ENV=development

# 🔢 API RATE LIMITS
WIFI_SEARCH_RATE_LIMIT=60  # requests per minute
GEMINI_RATE_LIMIT=100      # requests per minute

# 📊 CACHE SETTINGS
WIFI_CACHE_TIMEOUT=30      # seconds
GEMINI_CACHE_TIMEOUT=300   # seconds